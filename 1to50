@Component
public class CustomPermissionEvaluator implements PermissionEvaluator {
    
    @Autowired
    private UserService userService;
    
    @Override
    public boolean hasPermission(Authentication auth, Object targetDomainObject, Object permission) {
        // Complex permission logic
        if (targetDomainObject instanceof User) {
            User user = (User) targetDomainObject;
            return hasUserPermission(auth, user, permission.toString());
        }
        return false;
    }
    
    @Override
    public boolean hasPermission(Authentication auth, Serializable targetId, String targetType, Object permission) {
        // Permission based on ID and type
        if (targetType.equals("User")) {
            User user = userService.findById((Long) targetId);
            return hasUserPermission(auth, user, permission.toString());
        }
        return false;
    }
    
    private boolean hasUserPermission(Authentication auth, User user, String permission) {
        // Custom logic: if user owns the resource or has specific permission
        String username = auth.getName();
        if (user.getUsername().equals(username) && "read".equals(permission)) {
            return true;
        }
        // Check if user has admin authority
        return auth.getAuthorities().stream()
            .anyMatch(a -> a.getAuthority().equals("ROLE_ADMIN"));
    }
}
